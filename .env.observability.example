# ============================================================================
# OBSERVABILITY (LOCAL DOCKER-COMPOSE ONLY)
#
# Only needed when running the `observability` docker-compose profile locally:
#   docker compose --profile prod --profile observability up -d
#
# On Digital Ocean App Platform, configure Grafana Cloud as a standalone
# agent or use DO's built-in monitoring — these vars are NOT needed there.
# ============================================================================

# Grafana Cloud — get from grafana.com → My Account → Access Policies
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_TEMPO_URL=
GRAFANA_CLOUD_TEMPO_USER=
GRAFANA_CLOUD_API_KEY=

# Point the app at the local Alloy collector (only with observability profile)
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
