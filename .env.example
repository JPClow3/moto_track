# Canonical runtime configuration reference for Moto Track.
# Keep deployment docs pointing here instead of re-listing the same variables.
# Related docs:
# - README.md: local setup and validation
# - docs/deploy.md: target-specific deploy steps
# - docs/observability.md: Grafana Cloud + Alloy runbook

# ============================================================================
# LOCAL DEVELOPMENT (.env for local machine)
# ============================================================================
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,moto-track.net,www.moto-track.net
DATABASE_URL=sqlite:///db.sqlite3
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@moto-track.net
DJANGO_SITE_ID=1

# SMTP (SES or any SMTP provider)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.sa-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=<ses-smtp-username>
# EMAIL_HOST_PASSWORD=<ses-smtp-password>
# EMAIL_TIMEOUT=10

# Allauth email verification behavior
# Valid values: mandatory | optional | none. Default is `optional`: the
# confirmation email is sent in the background but does not block app access.
# ACCOUNT_EMAIL_VERIFICATION=optional
# ACCOUNT_CONFIRM_EMAIL_ON_GET=True
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=http

# Google OAuth (configured from environment; do not create SocialApp records in admin)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# PWA build/session defaults
# APP_BUILD_ID=local-dev
# SESSION_COOKIE_AGE=2592000

# Background tasks (Celery + Redis)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=
# REMINDER_PROCESS_INTERVAL_SECONDS=3600

# Browser push subscriptions
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_CONTACT_EMAIL=suporte@moto-track.net

# Encryption key for push subscription data at rest (defaults to SECRET_KEY if empty)
# Set a dedicated key to avoid data loss during SECRET_KEY rotation.
# PUSH_ENCRYPTION_KEY=generate-a-32-byte-key-here-...

# Error tracking (Sentry) - leave empty to disable
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.05

# Stripe Billing (Plano Pro)
# STRIPE_API_VERSION=2026-02-25.clover
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
# STRIPE_PAYMENT_METHOD_TYPES=pix,card

# Testing outside Docker: automated pytest runs require PostgreSQL, not SQLite.
# DJANGO_SETTINGS_MODULE=config.settings.test
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/motoapp_test

# Non-interactive admin creation (optional; avoids --password in shell history)
# DJANGO_CREATEADMIN_PASSWORD=...

# Bootstrap superuser in containers (optional; see `ensure_admin` management command)
# DJANGO_BOOTSTRAP_ENABLE=false
# DJANGO_BOOTSTRAP_ADMIN_USERNAME=admin
# DJANGO_BOOTSTRAP_ADMIN_PASSWORD=...
# DJANGO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ============================================================================
# DOCKER COMPOSE DEFAULTS (shared by dev/test/prod profiles)
# ============================================================================
# Compose derives each container's DATABASE_URL from POSTGRES_* automatically.
# Keep SQLite as the default for non-Docker local runs (DATABASE_URL above).
POSTGRES_DB=motoapp
POSTGRES_USER=motoapp
# Use a strong password for anything beyond local dev.
POSTGRES_PASSWORD=change-me-strong

# ============================================================================
# PRODUCTION BASELINE (Dokploy on EC2, direct Compose, manual VM, Railway)
# ============================================================================
# Start from this block for any production deployment. The minimal baseline is:
#
# DJANGO_SETTINGS_MODULE=config.settings.prod
# DJANGO_SECRET_KEY=<python -c "import secrets; print(secrets.token_urlsafe(64))">
# DJANGO_DEBUG=False
# DJANGO_USE_HTTPS=True
# SITE_DOMAIN=moto-track.net
# DJANGO_ALLOWED_HOSTS=moto-track.net,www.moto-track.net,54.86.112.205
# DATABASE_URL=postgresql://...
# CELERY_BROKER_URL=redis://redis:6379/0
# APP_BUILD_ID=<git-sha-or-release-id>
# SESSION_COOKIE_AGE=2592000
# VOLUME_MOUNT_PATH=/app
# WEB_PUSH_PUBLIC_KEY=<vapid-public-key>
# PUSH_ENCRYPTION_KEY=<dedicated-fernet-or-django-key>
#
# AWS / S3 (default file storage in prod)
# AWS_STORAGE_BUCKET_NAME=moto-track
# AWS_S3_REGION_NAME=us-east-1
# Optional on EC2/Lightsail with IAM instance profile attached:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Optional for S3-compatible endpoints; usually omit on standard AWS S3:
# AWS_S3_ENDPOINT_URL=https://moto-track.s3.us-east-1.amazonaws.com/
#
# Managed platforms usually supply some values for you:
# - Dokploy writes UI variables to `.env`; for this repo, production deploys
#   should run with the `prod` profile and without the `edge` profile.
# - Railway typically injects DATABASE_URL and public/private hostnames.
# - Direct Compose still expects POSTGRES_PASSWORD in `.env` when you use the
#   bundled Postgres service.

# Caching / Redis (prod)
# Used as the Django cache backend AND for cached_db sessions in prod.py.
# DB 1 is reserved for cache/sessions; Celery uses DB 0 via CELERY_BROKER_URL.
# REDIS_URL=redis://redis:6379/1
# DJANGO_CACHE_TIMEOUT=300

# Container resource limits (docker compose)
# Hard memory ceilings per service so a leak in one container cannot OOM-kill
# the host. Tune for the actual VPS size. Defaults are conservative.
# WEB_MEMORY_LIMIT=1g
# CELERY_WORKER_MEMORY_LIMIT=768m
# CELERY_BEAT_MEMORY_LIMIT=256m
# DB_MEMORY_LIMIT=1g
# REDIS_MEMORY_LIMIT=384m
# REDIS_MAX_MEMORY=256mb
# CADDY_MEMORY_LIMIT=128m

# Postgres tuning (override the upstream defaults once you know host RAM)
# Rough recipe: shared_buffers = 25% RAM, effective_cache_size = 75% RAM.
# POSTGRES_SHARED_BUFFERS=512MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
# POSTGRES_WORK_MEM=16MB
# POSTGRES_MAX_CONNECTIONS=100

# ============================================================================
# OBSERVABILITY (optional `observability` profile)
# ============================================================================
# See docs/observability.md for Grafana Cloud account setup, dashboards, and
# verification steps. Required only when starting:
#   docker compose --profile prod --profile observability up -d
#
# GRAFANA_CLOUD_PROM_URL=
# GRAFANA_CLOUD_PROM_USER=
# GRAFANA_CLOUD_LOKI_URL=
# GRAFANA_CLOUD_LOKI_USER=
# GRAFANA_CLOUD_TEMPO_URL=
# GRAFANA_CLOUD_TEMPO_USER=
# GRAFANA_CLOUD_API_KEY=
#
# OTel exporter. Leave empty unless the observability profile is running.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
# OTEL_SERVICE_NAME=moto-track-web
#
# Memory limits for the observability containers (host RAM permitting).
# ALLOY_MEMORY_LIMIT=200m
# PG_EXPORTER_MEMORY_LIMIT=64m
# REDIS_EXPORTER_MEMORY_LIMIT=48m
# CELERY_EXPORTER_MEMORY_LIMIT=96m
# CADVISOR_MEMORY_LIMIT=200m
