# ============================================================================
# LOCAL DEVELOPMENT (.env for local machine)
# ============================================================================
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=sqlite:///db.sqlite3
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@motoapp.local
#
# SMTP (SES or any SMTP provider)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.sa-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=<ses-smtp-username>
# EMAIL_HOST_PASSWORD=<ses-smtp-password>
# EMAIL_TIMEOUT=10
#
# Allauth email verification behavior
# ACCOUNT_EMAIL_VERIFICATION=mandatory  # mandatory|optional|none
# ACCOUNT_CONFIRM_EMAIL_ON_GET=True
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=http
DJANGO_SITE_ID=1
DJANGO_SECRET_KEY_PROD=change-me-long-random-50-plus-chars-for-local-prod-profile-only

# ============================================================================
# DOCKER COMPOSE (Postgres) - used when running via docker compose
# ============================================================================
# Keep SQLite as the default for non-Docker local runs (DATABASE_URL above).
# When using Compose, we point Django at the Postgres service using DATABASE_URL_DOCKER.
POSTGRES_DB=motoapp
POSTGRES_USER=motoapp
# Use a strong password for anything beyond local dev.
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL_DOCKER=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ============================================================================
# RAILWAY PRODUCTION SETTINGS
# ============================================================================
# Set these variables in Railway Dashboard → Variables
#
# DJANGO_SETTINGS_MODULE=config.settings.prod
# DJANGO_SECRET_KEY=<generate-with-python-secrets-module>
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-app.railway.app,www.your-app.railway.app
# DATABASE_URL=<railway-provides-this-automatically>
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@your-domain.com
# DJANGO_SITE_ID=1
