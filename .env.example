# Production-ready runtime configuration template for Moto Track.
# Copy this file to `.env`, replace every CHANGE_ME value, then deploy with
# the production compose profile. Local development overrides are documented at
# the bottom, but the active defaults below are intentionally production-first.
#
# Related docs:
# - README.md: setup and validation
# - docs/deploy.md: target-specific deploy steps
# - docs/observability.md: Grafana Cloud + Alloy runbook

# ============================================================================
# PRODUCTION BASELINE
# ============================================================================
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=False
DJANGO_USE_HTTPS=True
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_unique_secret_with_at_least_50_random_chars

SITE_DOMAIN=moto-track.net
DJANGO_ALLOWED_HOSTS=moto-track.net,www.moto-track.net
DJANGO_CSRF_TRUSTED_ORIGINS=https://moto-track.net,https://www.moto-track.net
DJANGO_SITE_ID=1

APP_BUILD_ID=CHANGE_ME_git_sha_or_release_id
DJANGO_LOG_LEVEL=INFO
SESSION_COOKIE_AGE=604800

# Email verification should be mandatory for production accounts.
ACCOUNT_EMAIL_VERIFICATION=mandatory
ACCOUNT_CONFIRM_EMAIL_ON_GET=True
ACCOUNT_DEFAULT_HTTP_PROTOCOL=https

# ============================================================================
# DATABASE, CACHE, AND BACKGROUND WORKERS
# ============================================================================
# For the bundled Docker Compose Postgres service, keep POSTGRES_PASSWORD and
# the password inside DATABASE_URL in sync. If you use managed Postgres, replace
# DATABASE_URL with the provider URL and keep POSTGRES_* only if the compose db
# service is still used.
POSTGRES_DB=motoapp
POSTGRES_USER=motoapp
POSTGRES_PASSWORD=CHANGE_ME_strong_database_password
DATABASE_URL=postgresql://motoapp:CHANGE_ME_strong_database_password@db:5432/motoapp

# Redis DB 0 is used by Celery; Redis DB 1 is used by Django cache/sessions.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=
REDIS_URL=redis://redis:6379/1
DJANGO_CACHE_TIMEOUT=300
CELERY_TASK_TIME_LIMIT=300
REMINDER_PROCESS_INTERVAL_SECONDS=3600

# Persistent media fallback path inside production containers.
VOLUME_MOUNT_PATH=/app

# ============================================================================
# STATIC/MEDIA STORAGE
# ============================================================================
# Production uses S3 through django-storages. On AWS compute, prefer an IAM
# instance/task role and leave AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY empty.
AWS_STORAGE_BUCKET_NAME=CHANGE_ME_s3_bucket_name
AWS_S3_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Set only for S3-compatible providers or custom endpoints. Leave empty for
# standard AWS S3.
AWS_S3_ENDPOINT_URL=

# ============================================================================
# EMAIL
# ============================================================================
# Production refuses to boot with SMTP selected and EMAIL_HOST empty.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=CHANGE_ME_smtp_host
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=CHANGE_ME_smtp_username
EMAIL_HOST_PASSWORD=CHANGE_ME_smtp_password
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@moto-track.net

# ============================================================================
# AUTH PROVIDERS
# ============================================================================
# Optional Google OAuth credentials. Leave empty to keep password/email auth only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# PWA PUSH NOTIFICATIONS
# ============================================================================
# Generate VAPID keys before enabling browser push notifications.
WEB_PUSH_PUBLIC_KEY=CHANGE_ME_vapid_public_key
WEB_PUSH_PRIVATE_KEY=CHANGE_ME_vapid_private_key
WEB_PUSH_CONTACT_EMAIL=suporte@moto-track.net

# Keep this stable after launch. Rotating it without a data migration can make
# encrypted push subscription fields unreadable.
PUSH_ENCRYPTION_KEY=CHANGE_ME_dedicated_stable_random_encryption_key

# ============================================================================
# STRIPE BILLING
# ============================================================================
# Leave Stripe values empty only when paid plans are intentionally disabled.
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PAYMENT_METHOD_TYPES=pix,card

# ============================================================================
# ERROR TRACKING
# ============================================================================
# Leave SENTRY_DSN empty to disable Sentry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05

# ============================================================================
# ADMIN BOOTSTRAP
# ============================================================================
# The production web container runs `ensure_admin` before Gunicorn. Keep this
# disabled unless you explicitly want the container to create/update an admin.
DJANGO_BOOTSTRAP_ENABLE=false
DJANGO_BOOTSTRAP_ADMIN_USERNAME=admin
DJANGO_BOOTSTRAP_ADMIN_PASSWORD=
DJANGO_BOOTSTRAP_ADMIN_EMAIL=admin@moto-track.net

# Non-interactive `python manage.py createadmin` helper.
DJANGO_CREATEADMIN_PASSWORD=

# ============================================================================
# DOCKER COMPOSE PRODUCTION TUNING
# ============================================================================
GUNICORN_WORKERS=3
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60

# Container memory ceilings. Tune these for the host size.
WEB_MEMORY_LIMIT=1g
CELERY_WORKER_MEMORY_LIMIT=768m
CELERY_BEAT_MEMORY_LIMIT=256m
DB_MEMORY_LIMIT=1g
REDIS_MEMORY_LIMIT=384m
REDIS_MAX_MEMORY=256mb
CADDY_MEMORY_LIMIT=128m

# Postgres tuning. These values are conservative for small VPS deployments.
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAX_CONNECTIONS=100

# ============================================================================
# OBSERVABILITY (optional `observability` profile)
# ============================================================================
# Required only when starting:
#   docker compose --profile prod --profile observability up -d
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_TEMPO_URL=
GRAFANA_CLOUD_TEMPO_USER=
GRAFANA_CLOUD_API_KEY=

# OTel exporter. Leave empty unless the observability profile is running.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=moto-track-web
OTEL_SERVICE_NAME_WORKER=moto-track-worker
OTEL_SERVICE_NAME_BEAT=moto-track-beat

# Memory limits for observability containers.
ALLOY_MEMORY_LIMIT=200m
PG_EXPORTER_MEMORY_LIMIT=64m
REDIS_EXPORTER_MEMORY_LIMIT=48m
CELERY_EXPORTER_MEMORY_LIMIT=96m
CADVISOR_MEMORY_LIMIT=200m

# ============================================================================
# MANAGED PLATFORM OVERRIDES
# ============================================================================
# Railway/Dokploy/etc. may inject their own DATABASE_URL, public hostnames, or
# volume paths. Set these only when your platform provides or requires them.
# RAILWAY_PUBLIC_DOMAIN=
# RAILWAY_PRIVATE_DOMAIN=
# RAILWAY_VOLUME_MOUNT_PATH=/data

# ============================================================================
# LOCAL DEVELOPMENT OVERRIDE
# ============================================================================
# For local development without Docker, copy this file to `.env`, then replace
# the production values above with this smaller block:
#
# DJANGO_SETTINGS_MODULE=config.settings.dev
# DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=insecure-local-dev-secret-key
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
# DATABASE_URL=sqlite:///db.sqlite3
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# ACCOUNT_EMAIL_VERIFICATION=none
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=http
#
# Docker development keeps PostgreSQL/Redis from compose:
#   docker compose --profile dev up --build
#
# Automated pytest runs require PostgreSQL, not SQLite:
# DJANGO_SETTINGS_MODULE=config.settings.test
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/motoapp_test
