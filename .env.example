# Client-visible values: `PUBLIC_` variables are exposed to the browser.
PUBLIC_NEON_AUTH_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth
PUBLIC_SITE_URL=http://localhost:5173

# Server-only secrets: never expose these keys to the client or prefix them with `PUBLIC_`.
# Pooled endpoint — used by the local Node dev server / scripts (postgres.js).
DATABASE_URL=postgresql://user:password@your-project-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Direct (non-pooler) endpoint — this is what a Cloudflare Hyperdrive config must point at.
DATABASE_URL_DIRECT=postgresql://user:password@your-project.region.aws.neon.tech/neondb?sslmode=require
NEON_AUTH_JWKS_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth/.well-known/jwks.json
MISTRAL_API_KEY=replace-me

R2_ACCOUNT_ID=replace-me
R2_BUCKET_NAME=moto-track-media
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_MONTHLY_PRICE_ID=price_replace_me
STRIPE_PRO_YEARLY_PRICE_ID=price_replace_me

RESEND_API_KEY=re_replace_me
DEFAULT_FROM_EMAIL=Moto Track <no-reply@moto-track.net>

# Web Push: the public key is safe for the browser; the other values stay server-only.
PUBLIC_VAPID_KEY=replace-me
VAPID_PRIVATE_KEY=replace-me
PUSH_ENCRYPTION_KEY=replace-with-a-long-random-secret
