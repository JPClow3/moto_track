# ============================================================================
# LOCAL DEVELOPMENT ONLY
#
# These vars are used exclusively by docker-compose for local development.
# Production variables are managed in the Digital Ocean App Platform dashboard
# (or declared in .do/app.yaml) — NOT in this file.
#
# Production secrets checklist: see .do/app.yaml
# ============================================================================

# Required by Django (any value is fine for local dev)
DJANGO_SECRET_KEY=insecure-local-dev-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.dev

# Required by the local `db` container (postgres) and all dev services
POSTGRES_PASSWORD=devonly

# ============================================================================
# OPTIONAL — only needed if you want to test these integrations locally.
# Leave blank to skip; the app boots fine without them in dev.
# Use TEST/sandbox keys here, never production ones.
# ============================================================================

# Stripe — get test keys from dashboard.stripe.com → Developers → API keys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...        # from `stripe listen --forward-to localhost:8000/billing/webhook/`
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...  # from Stripe Dashboard → Products
# STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Sentry — get DSN from sentry.io → your project → Settings → Client Keys
# SENTRY_DSN=https://...@sentry.io/...

# Google OAuth — get from console.cloud.google.com → Credentials
# Authorized redirect URI for local dev: http://localhost:8000/accounts/google/login/callback/
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
