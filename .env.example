# ============================================================================
# LOCAL DEVELOPMENT (.env for local machine)
# ============================================================================
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,moto-track.net,www.moto-track.net
DATABASE_URL=sqlite:///db.sqlite3
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@moto-track.net
#
# SMTP (SES or any SMTP provider)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.sa-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=<ses-smtp-username>
# EMAIL_HOST_PASSWORD=<ses-smtp-password>
# EMAIL_TIMEOUT=10
#
# Allauth email verification behavior
# Valid values: mandatory | optional | none
# ACCOUNT_EMAIL_VERIFICATION=mandatory
# ACCOUNT_CONFIRM_EMAIL_ON_GET=True
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=http
#
# Google OAuth (configured from environment; do not create SocialApp records in admin)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
DJANGO_SITE_ID=1
#
# PWA build/session defaults
# APP_BUILD_ID=local-dev
# SESSION_COOKIE_AGE=2592000
#
# Background tasks (Celery + Redis)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=
# REMINDER_PROCESS_INTERVAL_SECONDS=3600
#
# Browser push subscriptions
# WEB_PUSH_PUBLIC_KEY=
#
# Encryption key for push subscription data at rest (defaults to SECRET_KEY if empty)
# Set a dedicated key to avoid data loss during SECRET_KEY rotation.
# PUSH_ENCRYPTION_KEY=generate-a-32-byte-key-here-...
#
# Error tracking (Sentry) — leave empty to disable
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.05
#
# Stripe Billing (Plano Pro)
# STRIPE_API_VERSION=2026-02-25.clover
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
# STRIPE_PAYMENT_METHOD_TYPES=pix,card
#
# Non-interactive admin creation (optional; avoids --password in shell history)
# DJANGO_CREATEADMIN_PASSWORD=...
#
# Bootstrap superuser in containers (optional; see `ensure_admin` management command)
# DJANGO_BOOTSTRAP_ENABLE=false
# DJANGO_BOOTSTRAP_ADMIN_USERNAME=admin
# DJANGO_BOOTSTRAP_ADMIN_PASSWORD=...
# DJANGO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ============================================================================
# DOCKER COMPOSE (Postgres) - used when running via docker compose
# ============================================================================
# Keep SQLite as the default for non-Docker local runs (DATABASE_URL above).
# When using Compose, we point Django at the Postgres service using DATABASE_URL_DOCKER.
POSTGRES_DB=motoapp
POSTGRES_USER=motoapp
# Use a strong password for anything beyond local dev.
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL_DOCKER=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ============================================================================
# PRODUCTION (Docker Compose profile "prod", Lightsail VM, Coolify, Railway, etc.)
# ============================================================================
# `config.settings.prod` uses S3 for default file storage (django-storages).
# You MUST set at least:
#
# DJANGO_SETTINGS_MODULE=config.settings.prod
# DJANGO_SECRET_KEY=<python -c "import secrets; print(secrets.token_urlsafe(64))">
# DJANGO_DEBUG=False
# DJANGO_USE_HTTPS=True
# SITE_DOMAIN=moto-track.net
# DJANGO_ALLOWED_HOSTS=moto-track.net,www.moto-track.net,54.86.112.205
# DATABASE_URL=postgresql://...
# CELERY_BROKER_URL=redis://redis:6379/0
# APP_BUILD_ID=<git-sha-or-release-id>
# SESSION_COOKIE_AGE=2592000
# WEB_PUSH_PUBLIC_KEY=<vapid-public-key>
# PUSH_ENCRYPTION_KEY=<dedicated-fernet-or-django-key>
#
# AWS / S3 (bucket example: moto-track, region us-east-1)
# AWS_STORAGE_BUCKET_NAME=moto-track
# AWS_S3_REGION_NAME=us-east-1
# Optional; omit on EC2/Lightsail with IAM instance profile attached to the instance/role:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Optional; often omit for standard AWS S3 (default boto endpoint):
# AWS_S3_ENDPOINT_URL=https://moto-track.s3.us-east-1.amazonaws.com/
#
# Docker Compose profile `prod` (`docker compose --profile prod up`) also expects
# AWS_STORAGE_BUCKET_NAME and DJANGO_SECRET_KEY. Set them in `.env`.
#
# ---------------------------------------------------------------------------
# RAILWAY (legacy notes)
# ---------------------------------------------------------------------------
# DATABASE_URL=<railway-provides-this-automatically>
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=no-reply@moto-track.net
# DJANGO_SITE_ID=1

# ---------------------------------------------------------------------------
# Caching / Redis (prod)
# ---------------------------------------------------------------------------
# Used as the Django cache backend AND for cached_db sessions in prod.py.
# DB 1 is reserved for cache/sessions; Celery uses DB 0 via CELERY_BROKER_URL.
# REDIS_URL=redis://redis:6379/1
# DJANGO_CACHE_TIMEOUT=300

# ---------------------------------------------------------------------------
# Container resource limits (docker-compose)
# ---------------------------------------------------------------------------
# Hard memory ceilings per service so a leak in one container can't OOM-kill
# the host. Tune for the actual VPS size. Defaults are conservative.
# WEB_MEMORY_LIMIT=1g
# CELERY_WORKER_MEMORY_LIMIT=768m
# CELERY_BEAT_MEMORY_LIMIT=256m
# DB_MEMORY_LIMIT=1g
# REDIS_MEMORY_LIMIT=384m
# REDIS_MAX_MEMORY=256mb
# CADDY_MEMORY_LIMIT=128m

# ---------------------------------------------------------------------------
# Postgres tuning (override the upstream defaults — they are extremely
# conservative). Set these once you know how much RAM the host has.
# Rough recipe: shared_buffers = 25% RAM, effective_cache_size = 75% RAM.
# ---------------------------------------------------------------------------
# POSTGRES_SHARED_BUFFERS=512MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
# POSTGRES_WORK_MEM=16MB
# POSTGRES_MAX_CONNECTIONS=100
