{
  "name": "moto-track",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "supabase:types": "node scripts/generate-db-types.mjs",
    "db:migrate": "supabase db push",
    "import:legacy": "tsx scripts/import-legacy-data.ts",
    "worker:dev": "wrangler dev -c workers/reminders/wrangler.toml",
    "worker:deploy": "wrangler deploy -c workers/reminders/wrangler.toml"
  },
  "dependencies": {
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.53.0",
    "@sveltejs/adapter-cloudflare": "^7.0.5",
    "@sveltejs/kit": "^2.27.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.468.0",
    "marked": "^18.0.6",
    "stripe": "^22.3.2",
    "svelte": "^5.38.0",
    "sveltekit-superforms": "^2.27.1",
    "uuid": "^11.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.0",
    "@playwright/test": "^1.54.0",
    "@sveltejs/adapter-auto": "^6.0.1",
    "@sveltejs/package": "^2.3.12",
    "@types/node": "^22.13.4",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.31.0",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^17.7.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte-check": "^4.3.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.26.0"
  }
}
