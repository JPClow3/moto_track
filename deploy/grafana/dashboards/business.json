{
  "title": "Moto Track — Business Metrics",
  "uid": "moto-track-business",
  "tags": ["moto-track", "business"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "America/Sao_Paulo",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "query": "label_values(up, env)",
        "current": { "text": "production", "value": "production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Signups (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum(increase(moto_signups_total{env=\"$env\"}[24h]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Signups by method (rate / 5m)",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum by (method) (rate(moto_signups_total{env=\"$env\"}[5m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Stripe webhooks by event_type and outcome",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum by (event_type, outcome) (rate(moto_stripe_webhook_total{env=\"$env\"}[5m]))",
          "legendFormat": "{{event_type}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Stripe webhook p95 latency by event",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (event_type, le) (rate(moto_stripe_webhook_duration_seconds_bucket{env=\"$env\"}[5m])))",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reminders job — runs by outcome",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(moto_reminders_run_total{env=\"$env\"}[15m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Reminders processed by action",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum by (action) (rate(moto_reminders_processed_total{env=\"$env\"}[15m]))",
          "legendFormat": "{{action}}"
        }
      ]
    }
  ]
}
